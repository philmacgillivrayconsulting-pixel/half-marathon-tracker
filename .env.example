NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional but recommended: bypasses RLS for server-side writes (OAuth tokens, plans).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_ADMIN_PIN=1234

# Strava OAuth — create an app at https://www.strava.com/settings/api
# Authorization callback domain must match the deploy origin (e.g. localhost).
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Enable the Google Calendar API on the same project.
# Authorized redirect URI: {origin}/api/runna/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
